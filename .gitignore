# ---------------------------------------------------------------------------
# Agent working artifacts — NOT needed for the app to run. Tracking these in
# git caused recurring merge conflicts (PR #43). They live on disk for the
# build agents but must stay out of version control.
# ---------------------------------------------------------------------------
test_reports/
test_result.md
/app/test_result.md
memory/
frontend/node_modules/.cache/default-development/1.pack
frontend/node_modules/.cache/default-development/5.pack
.credentials

# Platform-generated run summary (artifact — not needed to run the app).
# Keep .emergent/emergent.yml tracked; ignore only the volatile summary.
.emergent/summary.txt
frontend/node_modules/.cache/default-development/2.pack
