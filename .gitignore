# ---------------------------------------------------------------------------
# Agent working artifacts — NOT needed for the app to run. Tracking these in
# git caused recurring merge conflicts (PR #43). They live on disk for the
# build agents but must stay out of version control.
# ---------------------------------------------------------------------------
test_reports/
test_result.md
/app/test_result.md
memory/
frontend/node_modules/.cache/default-development/1.pack
frontend/node_modules/.cache/default-development/5.pack
.credentials

# Platform-generated run summary (artifact — not needed to run the app).
# Keep .emergent/emergent.yml tracked; ignore only the volatile summary.
.emergent/summary.txt

# Test suite + ad-hoc QA scripts. These are regenerated by the testing agent on
# every iteration/fork, which caused recurring delete/modify merge conflicts on
# PR sync (#43). They live on disk (local pytest + app run fine) but stay OUT of
# version control so merges never block on them. Operational seed scripts
# (backend/scripts/seed_*.py, pilot_cleanup.py) remain tracked.
backend/tests/
backend_test.py
backend/scripts/collision_deep_test.py
backend/scripts/download_all_exports.py
backend/scripts/full_system_test.py

# Root-level ad-hoc test scripts (testing-agent artifacts).
/test_theme_fix.py
/test_*.py
frontend/node_modules/.cache/default-development/2.pack
frontend/node_modules/.cache/default-development/4.pack
frontend/node_modules/.cache/default-development/6.pack
frontend/node_modules/.cache/default-development/9.pack
